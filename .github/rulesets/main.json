{
  "name": "main",
  "target": "branch",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "include": ["refs/heads/main"],
      "exclude": []
    }
  },
  "rules": [
    {
      "type": "deletion"
    },
    {
      "type": "non_fast_forward"
    },
    {
      "type": "required_signatures"
    },
    {
      "type": "pull_request",
      "parameters": {
        "required_approving_review_count": 0,
        "dismiss_stale_reviews_on_push": true,
        "require_code_owner_review": true,
        "require_last_push_approval": false,
        "required_review_thread_resolution": true
      }
    },
    {
      "type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": true,
        "required_status_checks": [
          { "context": "verify" },
          { "context": "test-matrix (ubuntu-latest, 3.9)" },
          { "context": "test-matrix (ubuntu-latest, 3.10)" },
          { "context": "test-matrix (ubuntu-latest, 3.11)" },
          { "context": "test-matrix (ubuntu-latest, 3.12)" },
          { "context": "test-matrix (ubuntu-latest, 3.13)" },
          { "context": "test-matrix (macos-latest, 3.9)" },
          { "context": "test-matrix (macos-latest, 3.10)" },
          { "context": "test-matrix (macos-latest, 3.11)" },
          { "context": "test-matrix (macos-latest, 3.12)" },
          { "context": "test-matrix (macos-latest, 3.13)" }
        ]
      }
    }
  ],
  "bypass_actors": []
}
